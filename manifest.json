{
	"manifest_version": 3,
	"name": "Blue Dot Replacement",
	"description": "Flash an alert icon when an unfocused tab's title changes.",
	"version": "1.3.2",
	"author": "Will Groenendyk",
	"options_ui": {
		"page": "options.html",
		"open_in_tab": false
	},
	"background": {
		"service_worker": "bg.js"
	},
	"icons": {
		"16": "img/icon16.png",
		"32": "img/icon32.png",
		"128": "img/icon128.png"
	},
	"web_accessible_resources" : [
		{
			"resources": [ "img/alarm.png" ],
			"matches": [ "http://*/*", "https://*/*" ]
		}
	],
	"short_name" : "BDR",
	"permissions": [
		"tabs",
		"storage",
		"scripting"
	],
	"host_permissions": [
		"https://*/*",
		"http://*/*"
	]
}
